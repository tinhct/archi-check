# GitHub App Configurations
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Upstash Redis configurations
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# LLM Provider Configuration
LLM_PROVIDER=gemini # Or "claude"
LLM_API_KEY=

# Complexity Heuristic Configurations
COMPLEXITY_THRESHOLD=5
AGENT_RELIANCE_THRESHOLD=0.7 # 70% contribution

# Staging & Live-Fire Interception Configurations (Epic 5)
# Set to "shadow" to intercept outbound writes without mutating GitHub/Redis state
# ARCHICHECK_MODE=shadow
# Set to "json" to print intercepted payloads as minified structured JSON to stdout
# ARCHICHECK_SHADOW_FORMAT=json

