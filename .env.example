# 🛡️ ArchiCheck Environment Template (.env.example)

# ─── GitHub App Configurations ────────────────────────────────────────────────
# Get these from your GitHub App Settings page
GITHUB_APP_ID=
# The RSA private key generated for your app. 
# WARNING: In .env.local, wrap this multiline block in double quotes:
# GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Set to true to run fully offline (mocks Octokit GitHub calls and Upstash Redis pings)
# Highly recommended for offline local development and test runs.
MOCK_GITHUB=true

# ─── Upstash Redis Configurations ─────────────────────────────────────────────
# Required for persisting PR gating/quiz states across stateless webhook deliveries
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── LLM Provider Configurations ──────────────────────────────────────────────
# Selected core AI model provider: "gemini" or "claude"
LLM_PROVIDER=gemini
# Selected model execution type: 
#   - "mock"             (Uses golden static local test fixtures)
#   - "gemini-developer" (Uses free-tier Google AI Studio API developer keys)
#   - "vertex"           (Uses enterprise Vertex AI client)
LLM_PROVIDER_TYPE=mock
# Required if LLM_PROVIDER_TYPE is set to "gemini-developer"
LLM_API_KEY=
# Optional GCP credentials JSON (required if LLM_PROVIDER_TYPE is set to "vertex")
GOOGLE_CREDS_JSON=

# ─── Gating & Heuristics Thresholds ───────────────────────────────────────────
# Integer complexity threshold score before trigger-gating a PR (defaults to 5)
COMPLEXITY_THRESHOLD=5
# Float decimal proportion of AI-generated cues to trigger-gate a PR (defaults to 0.7)
AGENT_RELIANCE_THRESHOLD=0.7

# ─── Alerting & Telemetry Budgets ─────────────────────────────────────────────
# Dollar/Token limit cap before triggering budget alerts (defaults to 200)
TELEMETRY_BUDGET_LIMIT=200
# Optional Slack Webhook endpoint for receiving telemetry burn notifications
SLACK_WEBHOOK_URL=

# ─── Staging & Live-Fire Interception Configurations ──────────────────────────
# Set to "shadow" to intercept outgoing status lock & comment calls and print
# them locally to console without mutating active GitHub or Redis states
# ARCHICHECK_MODE=shadow
# Set to "json" to print shadow intercepted logs in minified structured JSON format
# ARCHICHECK_SHADOW_FORMAT=json
